---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="aahmed.ca — Blog">
  <ul class="post-list">
    {posts.map(post => (
      <li>
        <span class="post-date">
          {post.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' })}
        </span>
        <a href={`/blog/${post.slug}`} class="post-title">{post.data.title}</a>
      </li>
    ))}
  </ul>
  {posts.length === 0 && <p style="color: var(--text-subtle)">No posts yet.</p>}
</Base>
