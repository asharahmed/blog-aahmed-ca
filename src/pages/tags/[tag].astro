---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Set(posts.flatMap(p => p.data.tags));
  return [...tags].map(tag => ({
    params: { tag },
    props: {
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const byYear: Record<number, typeof posts> = {};
for (const post of posts) {
  const y = post.data.date.getFullYear();
  (byYear[y] ??= []).push(post);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---
<Base title={`${tag} — aahmed.ca`}>
  <a href="/tags" class="back-link">← Tags</a>
  <h1 class="page-title">{tag}</h1>
  <div class="post-index">
    {years.map(year => (
      <div class="year-group">
        <span class="year-label">{year}</span>
        <ul class="year-posts">
          {byYear[year].map(post => (
            <li>
              <span class="post-date">
                {post.data.date.toLocaleDateString('en-CA', { month: 'short', day: 'numeric' })}
              </span>
              <a href={`/blog/${post.slug}`} class="post-link">
                <span class="post-link-text">{post.data.title}</span>
                <span class="post-link-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Base>
